{
  "extends": "../../tooling/typescript/base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    },
    "allowJs": true,
    "incremental": true
  },
  "include": ["src", "next-env.d.ts", "*.ts", "*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
