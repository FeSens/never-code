{
  "name": "@never-code/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    }
  },
  "scripts": {
    "generate": "set -a && . ../../.env && drizzle-kit generate",
    "migrate": "set -a && . ../../.env && drizzle-kit migrate",
    "push": "set -a && . ../../.env && drizzle-kit push",
    "studio": "drizzle-kit studio",
    "seed": "tsx --env-file=../../.env src/seed.ts",
    "reset": "tsx --env-file=../../.env src/reset.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@never-code/shared": "workspace:*",
    "drizzle-orm": "^0.39.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
